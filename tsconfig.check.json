{
  "//": "Typecheck everything (src + bin + scripts + tests) without emitting.",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "rewriteRelativeImportExtensions": false
  },
  "include": [
    "src/**/*.ts",
    "bin/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
